# ═══════════════════════════════════════════════════════
# UniversalBooks — Environment Variables
# ═══════════════════════════════════════════════════════
# Copy this file:  cp .env.example .env.local
# Then fill in your actual API keys and webhook URLs.

# LiveKit Cloud
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
SIP_OUTBOUND_TRUNK_ID=your_sip_trunk_id

# SIP Provider (VoBiz)
SIP_Domain=your_sip_domain
username=your_sip_username
password=your_sip_password

# AWS Bedrock (LLM via Claude Haiku)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=ap-south-1

# STT/TTS — Sarvam AI
SARVAM_API_KEY=your_sarvam_api_key

# Backup LLM — Groq (optional)
GROQ_API_KEY=your_groq_api_key

# N8N Webhooks
N8N_WHATSAPP_WEBHOOK_URL=https://your-n8n-instance.com/webhook/whatsapp
N8N_SMS_WEBHOOK_URL=https://your-n8n-instance.com/webhook/sms
N8N_CALLBACK_WEBHOOK_URL=https://your-n8n-instance.com/webhook/callback
N8N_EMAIL_WEBHOOK_URL=https://your-n8n-instance.com/webhook/email
